<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:background="@android:color/white"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:minWidth="280dp"
    android:minHeight="80dp"
    android:elevation="4dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">

        <TextView
            android:id="@+id/addictionNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Addiction"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121" />

        <TextView
            android:id="@+id/currentCountTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Текущий счет: 5"
            android:textSize="16sp"
            android:textColor="#757575"
            android:layout_marginTop="4dp" />
    </LinearLayout>


    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginStart="16dp"
        android:weightSum="2">

        <ImageButton
            android:id="@+id/successfulDayButton"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:backgroundTint="#4CAF50"
            android:background="@drawable/rounded_button"
            android:src="@drawable/ic_check"
            android:contentDescription="Успешный день"
            android:layout_marginEnd="12dp"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/unsuccessfulDayButton"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:backgroundTint="#F44336"
            android:background="@drawable/rounded_button"
            android:src="@drawable/ic_close"
            android:contentDescription="Неуспешный день"
            app:tint="@android:color/white" />
    </LinearLayout>

</LinearLayout>
